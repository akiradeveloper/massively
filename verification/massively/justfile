image_name := "massively-verification:lean-4.32.0"

default:
    @just --list

# Build the shared pinned verification environment.
image:
    docker build --tag {{ image_name }} ..

# Check the proof with the host Lean installation.
proof-local:
    cd proof && lake build

# Check every definition and theorem in the pinned Docker environment.
proof: image
    docker run --rm --user "$(id -u):$(id -g)" -e HOME=/tmp -v "$PWD/..:/workspace" -w /workspace/massively/proof {{ image_name }} lake build
