image_name := "massively-traversal-algebra:lean-4.32.0"

default:
    @just --list

# Build the reproducible LaTeX/Lean proof environment.
image:
    docker build --tag {{ image_name }} .

# Compile the paper in Docker and publish the latest readable PDF.
paper: image
    docker run --rm --user "$(id -u):$(id -g)" -e HOME=/tmp -e TZ=UTC -v "$PWD:/workspace" -w /workspace {{ image_name }} bash -c 'mkdir -p paper/build && latexmk -g -cd -pdf -interaction=nonstopmode -halt-on-error -outdir=build paper/main.tex'
    cp paper/build/main.pdf paper/paper.pdf

# Check all Lean definitions and proofs in Docker.
proof: image
    docker run --rm --user "$(id -u):$(id -g)" -e HOME=/tmp -v "$PWD:/workspace" -w /workspace/proof {{ image_name }} bash -c 'lake build'

# Compare the independent sequential CPU oracle with Massively on the host GPU.
oracle:
    cargo nextest run -p traversal-algebra-oracle --test conformance

# Check complete Traversal Algebra graph algorithms against their CPU oracles.
algorithms:
    cargo nextest run -p graph-algorithms --test oracle

# Benchmark the complete Traversal Algebra graph algorithms.
bench-graph:
    cargo bench -p graph-algorithms --bench algorithms

# Check the complete research artifact.
check: paper proof oracle algorithms
